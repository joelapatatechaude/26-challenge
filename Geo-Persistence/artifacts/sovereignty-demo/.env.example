# PPT Skills Agent — base URL for the LangGraph presentation agent
# Leave empty when the agent runs on the same host (same-origin proxy via Vite).
# Set to the agent's public URL for split deployments, e.g.:
#   http://localhost:8080         (local bare-metal)
#   http://ppt-agent:8080         (docker-compose service name)
#   https://ppt-agent.apps.cluster.example.com  (OpenShift Route)
VITE_PPT_AGENT_URL=http://localhost:8080
