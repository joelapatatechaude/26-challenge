FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn[standard]==0.30.0 \
    pyjwt==2.9.0 \
    httpx==0.27.0 \
    python-multipart==0.0.9 \
    jinja2==3.1.4

COPY bridge/ ./bridge/

EXPOSE 3000

CMD ["uvicorn", "bridge.main:app", "--host", "0.0.0.0", "--port", "3000", "--reload"]
