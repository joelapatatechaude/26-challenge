# ── ONLYOFFICE file bridge ────────────────────────────────────────────────────
# JWT secret shared between the file-bridge and ONLYOFFICE Document Server.
# Change this before any non-local deployment.
ONLYOFFICE_JWT_SECRET=ppt-skills-dev-secret

# Externally reachable base URL of the file-bridge service.
# ONLYOFFICE calls back to this URL to fetch the file and post saves.
# For local dev: http://localhost:3000
# For remote:    https://your-bridge-hostname
BRIDGE_PUBLIC_URL=http://localhost:3000

# ── LLM configuration (LiteLLM — any provider) ───────────────────────────────
LLM_MODEL=gpt-4o
LLM_API_BASE=                  # For Ollama/vLLM: http://localhost:11434
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Provider API keys (set whichever you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
