# ── 26-Challenge dev environment ─────────────────────────────────────────────
# Copy this file to .env and fill in the values before running dev-compose.yml.
#   cp .env.dev.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM configuration (ppt-agent) ────────────────────────────────────────────
# Model identifier passed to LiteLLM. Examples:
#   gpt-4o                      (OpenAI)
#   anthropic/claude-opus-4-5   (Anthropic)
#   openai/mistral-large        (vLLM/Ollama proxy)
LLM_MODEL=gpt-4o

# For Ollama, vLLM, or any OpenAI-compatible proxy set the base URL here.
# Leave empty when using OpenAI directly.
LLM_API_BASE=

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── LLM Provider API keys ─────────────────────────────────────────────────────
# Set whichever key matches LLM_MODEL above.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the ppt-agent API.
# The default (http://localhost:5173) matches the Vite dev server port.
CORS_ALLOWED_ORIGINS=http://localhost:5173


# ── PostgreSQL (profile: db) ──────────────────────────────────────────────────
POSTGRES_DB=challenge_dev
POSTGRES_USER=challenge
POSTGRES_PASSWORD=challenge_dev_secret


# ── ONLYOFFICE / file-bridge (profile: office) ───────────────────────────────
# JWT secret shared between ONLYOFFICE and the file-bridge service.
# Change this before any non-local deployment.
ONLYOFFICE_JWT_SECRET=ppt-skills-dev-secret

# Externally reachable URL of the file-bridge — ONLYOFFICE callbacks here.
# For local dev: http://localhost:3000
# For remote:    https://your-bridge-hostname
BRIDGE_PUBLIC_URL=http://localhost:3000
